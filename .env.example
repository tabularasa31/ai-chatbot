DATABASE_URL=postgresql://user:password@localhost:5432/chatbot
JWT_SECRET=your-secret-key-min-32-chars
OPENAI_API_KEY=sk-...
# Required for encrypting client OpenAI keys (generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
ENCRYPTION_KEY=
ENVIRONMENT=development

# CORS configuration (comma-separated list of allowed origins)
# Default: http://localhost:3000,https://getchat9.live
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://getchat9.live
