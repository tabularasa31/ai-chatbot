# Database
DATABASE_URL=postgresql://user:password@localhost:5432/chatbot

# Auth
JWT_SECRET=your-secret-key-min-32-chars

# Internal eval QA (/eval/*) — use a distinct secret in production
EVAL_JWT_SECRET=your-eval-secret-min-32-chars

# Encryption key for storing client OpenAI keys
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# Environment
ENVIRONMENT=development
ALLOWED_HOSTS=*
WIDGET_MESSAGE_MAX_CHARS=4000
WIDGET_CHAT_PER_CLIENT_RATE=1000/minute

# Frontend URL (used in email links)
FRONTEND_URL=http://localhost:3000

# Email (Brevo)
BREVO_API_KEY=
EMAIL_FROM=no-reply@getchat9.live

# CORS (comma-separated list of allowed origins)
# Add all frontend domains: local dev + production
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://getchat9.live

# Note: No global OPENAI_API_KEY needed.
# Each client provides their own OpenAI key via the dashboard.

# Next.js frontend (frontend/.env.local or Vercel env — set before build)
# NEXT_PUBLIC_API_URL=https://api.example.com
# Public client id from dashboard embed snippet (ch_...), not the secret api_key:
# NEXT_PUBLIC_LANDING_DEMO_BOT_ID=ch_
# NEXT_PUBLIC_LANDING_DEMO_CLIENT_ID=ch_  # legacy alias for the same public bot ID
