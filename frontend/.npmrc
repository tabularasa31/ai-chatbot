# auto-install peer deps so workspace packages don't have to redeclare every transitive peer.
auto-install-peers=true

# TODO(PR 2/3): flip back to strict-peer-dependencies=true once the React 18 / Preact 10
# coexistence inside apps/widget-app/ is stabilized. Kept loose during the migration to
# avoid noisy install failures from transitive peer mismatches.
strict-peer-dependencies=false
