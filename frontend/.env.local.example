NEXT_PUBLIC_API_URL=http://localhost:8000

# Shared with the backend (same value as backend JWT_SECRET). Lets Server
# Components decode the auth cookie locally instead of calling GET /auth/me.
# Server-only — must NOT be NEXT_PUBLIC_. Optional: when unset, components
# fall back to fetching /auth/me client-side.
JWT_SECRET=

# PostHog analytics — get from posthog.com > Project Settings > API Keys
NEXT_PUBLIC_POSTHOG_KEY=phc_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# Public origin (with /v1/ path) of the standalone widget-app deploy that the
# in-dashboard support widget loads via iframe. Defaults to the production
# Vercel project; override locally to point at a dev widget build.
NEXT_PUBLIC_WIDGET_BASE_URL=https://widget.getchat9.live/v1/

# Public bot id for the Chat9 dogfood bot. Used by both the in-dashboard
# support widget and the landing-page live demo. Without it the floating
# chat bubble doesn't render and the landing demo shows a placeholder.
NEXT_PUBLIC_CHAT9_BOT_ID=
